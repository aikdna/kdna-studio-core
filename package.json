{
  "name": "@aikdna/kdna-studio-core",
  "version": "1.9.1",
  "description": "Official KDNA Studio Core SDK for authoring, reviewing, compiling, and exporting .kdna judgment assets through the KDNA toolchain.",
  "type": "commonjs",
  "main": "src/index.js",
  "files": [
    "src/",
    "schemas/",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aikdna/kdna-studio-core.git"
  },
  "bugs": {
    "url": "https://github.com/aikdna/kdna-studio-core/issues"
  },
  "homepage": "https://github.com/aikdna/kdna-studio-core#readme",
  "keywords": [
    "kdna",
    "domain-judgment",
    "authoring",
    "judgment-cards",
    "provenance",
    "compile",
    "validate"
  ],
  "dependencies": {
    "@aikdna/kdna-cli": "0.33.0",
    "@aikdna/kdna-core": "0.18.0",
    "cbor-x": "^1.6.4"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "find src tests scripts -name '*.js' -print0 | xargs -0 -n1 node --check",
    "test": "node --test tests/*.test.js",
    "test:all": "npm run lint && npm test",
    "release:check": "node scripts/release-check.js",
    "prepublishOnly": "npm test && npm run release:check"
  }
}
