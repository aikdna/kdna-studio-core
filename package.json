{
  "name": "@aikdna/kdna-studio-core",
  "version": "1.5.3",
  "description": "Official KDNA Studio Core SDK for authoring, locking, compiling, and exporting .kdna judgment assets through the KDNA toolchain.",
  "type": "commonjs",
  "main": "src/index.js",
  "files": [
    "src/",
    "schemas/",
    "README.md"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aikdna/kdna-studio-core.git"
  },
  "keywords": [
    "kdna",
    "domain-judgment",
    "authoring",
    "judgment-cards",
    "human-lock",
    "compile",
    "validate"
  ],
  "dependencies": {
    "@aikdna/kdna-core": "^0.11.1",
    "cbor-x": "^1.6.4"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "find src tests -name '*.js' -print0 | xargs -0 -n1 node --check",
    "test": "node --test tests/*.test.js",
    "test:all": "npm run lint && npm test"
  },
  "devDependencies": {
    "@aikdna/kdna-cli": "^0.25.0"
  }
}
